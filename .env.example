# ─────────────────────────────────────────────────────────────────────────────
# SAQIB RICE MILLS — .env.example
# Copy to .env.local and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# ── FIREBASE / FIRESTORE ────────────────────────────────────────────────────
# Get from Firebase Console > Project Settings > Service Accounts > Generate Key
FIREBASE_PROJECT_ID="ricemill-89192"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@ricemill-89192.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ── IMGBB (Product Image Upload) ────────────────────────────────────────────
# Get from https://api.imgbb.com/
IMGBB_API_KEY="your-imgbb-api-key"

# ── NEXT.JS APP ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Saqib Rice Mills"

# ── JWT / Auth Secret ────────────────────────────────────────────────────────
# Used for JWT signing and admin registration verification
ADMIN_SECRET="change-this-to-a-strong-random-string"

# ─────────────────────────────────────────────────────────────────────────────
